      {
         "datasource": {
            "type": "prometheus",
            "uid": "$datasource"
         },
         "description": "A time series of task runtime percentiles (P50, P95, P99) grouped by task name.",
         "fieldConfig": {
            "defaults": {
               "custom": {
                  "fillOpacity": 10
               },
               "unit": "s"
            },
            "overrides": [
               {
                  "matcher": {
                     "id": "byName",
                     "options": "P50"
                  },
                  "properties": [
                     {
                        "id": "color",
                        "value": {
                           "fixedColor": "green",
                           "mode": "fixed"
                        }
                     }
                  ]
               },
               {
                  "matcher": {
                     "id": "byName",
                     "options": "P95"
                  },
                  "properties": [
                     {
                        "id": "color",
                        "value": {
                           "fixedColor": "yellow",
                           "mode": "fixed"
                        }
                     }
                  ]
               },
               {
                  "matcher": {
                     "id": "byName",
                     "options": "P99"
