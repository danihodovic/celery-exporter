               },
               "exemplar": false,
               "expr": "sum (\n  round(\n    increase(\n      celery_task_failed_total{\n        cluster=\"$cluster\",\nnamespace=\"$namespace\",\njob=~\"$job\"\n,\nqueue_name=~\"$queue_name\"\n,\nname=~\"$task\",\nname!~\"None\"\n\n      }[$__rate_interval]\n    )\n  )\n) by (name, exception) > 0\n",
