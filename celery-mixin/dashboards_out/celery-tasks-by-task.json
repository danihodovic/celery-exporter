                  "properties": [
                     {
                        "id": "color",
                        "value": {
                           "fixedColor": "red",
                           "mode": "fixed"
                        }
                     }
                  ]
               }
            ]
         },
         "gridPos": {
            "h": 6,
            "w": 24,
            "x": 0,
            "y": 30
         },
         "id": 7,
         "options": {
            "legend": {
               "calcs": [
                  "mean",
