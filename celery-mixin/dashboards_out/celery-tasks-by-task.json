      },
      {
         "datasource": {
            "type": "prometheus",
            "uid": "$datasource"
         },
         "description": "A time series of tasks completed including succeeded, failed, sent, received, rejected, retried and revoked tasks grouped by task name.",
         "fieldConfig": {
            "defaults": {
